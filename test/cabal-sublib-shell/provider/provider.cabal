cabal-version:       3.0
name:                provider
version:             0.1.0.0
license:             MIT
author:              haskell.nix test
maintainer:          haskell.nix@iohk.io
build-type:          Simple

library
  exposed-modules:     Provider
  build-depends:       base, provider:slib
  hs-source-dirs:      src
  default-language:    Haskell2010

library slib
  exposed-modules:     Provider.Slib
  build-depends:       base
  hs-source-dirs:      slib
  visibility:          public
  default-language:    Haskell2010
