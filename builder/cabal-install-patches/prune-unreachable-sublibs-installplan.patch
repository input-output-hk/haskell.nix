Keep install-plan validator and elaborator in sync with solver-side
sublib pruning.

Companion to prune-unreachable-sublibs.patch (in cabal-install-solver).
Without this patch, two later phases still see the sublibs the solver
dropped and fail:

  1. `configuredPackageProblems` in Distribution.Client.Dependency re-runs
     `finalizePD` and `enabledBuildDepends` on the source
     GenericPackageDescription.  The result includes the unreachable
     sublibs' deps, which the solver did not plan — reported as "no
     package has been selected to satisfy it", failing the install plan.

  2. `elaborateSolverToCommon` in Distribution.Client.ProjectPlanning
     finalizes the PackageDescription again for elaboration.  The result
     is fed to Cabal's ConfiguredComponent pass, which walks every
     subLibrary and errors "Dependency on unbuildable package X" when
     the missing deps can't be found.

This patch runs the same reachability analysis on the finalized
PackageDescription at both sites and drops unreachable sublibs before
use.  The helper `reachablePDSubLibs` is defined in Dependency.hs (and
exported) so both sites share one implementation.

--- a/src/Distribution/Client/Dependency.hs
+++ b/src/Distribution/Client/Dependency.hs
@@ -65,6 +65,9 @@
   , addSetupCabalMinVersionConstraint
   , addSetupCabalMaxVersionConstraint
   , addSetupCabalProfiledDynamic
+
+    -- ** haskell.nix helpers
+  , reachablePDSubLibs
   ) where

 import Distribution.Client.Compat.Prelude
@@ -96,6 +99,7 @@
   , mergeBy
   )
 import qualified Distribution.Compat.Graph as Graph
+import qualified Distribution.Compat.NonEmptySet as NonEmptySet
 import Distribution.Compiler
   ( CompilerInfo (..)
   )
@@ -1108,13 +1112,59 @@
             -- but no finalizePDs picks components we are not building, eg. exes.
             -- See #3775
             --
-            filter
-              ((/= thisPkgName) . dependencyName)
-              (PD.enabledBuildDepends resolvedPkg compSpec)
-              ++ maybe [] PD.setupDepends (PD.setupBuildInfo resolvedPkg)
+            -- haskell.nix: additionally drop deps coming from sublibs that no
+            -- component in this package reaches.  Must stay in sync with the
+            -- solver-side pruning in
+            -- Distribution.Solver.Modular.IndexConversion; otherwise the
+            -- install-plan validator sees deps the solver didn't plan and
+            -- fails with "no package has been selected to satisfy it".
+            let reach       = reachablePDSubLibs resolvedPkg
+                keepSubLib lib = case PD.libName lib of
+                  PD.LSubLibName n -> n `Set.member` reach
+                  _                -> True
+                prunedPkg = resolvedPkg
+                  { PD.subLibraries = filter keepSubLib (PD.subLibraries resolvedPkg) }
+            in filter
+                 ((/= thisPkgName) . dependencyName)
+                 (PD.enabledBuildDepends prunedPkg compSpec)
+                 ++ maybe [] PD.setupDepends (PD.setupBuildInfo prunedPkg)
           Left _ ->
             error "configuredPackageInvalidDeps internal error"
+
+-- | Sublib component names reachable from the main library or any executable
+-- of a finalized PackageDescription.  Mirrors the GenericPackageDescription
+-- pruning in Distribution.Solver.Modular.IndexConversion so solver output
+-- and install-plan validation agree on which sublibs are live.
+reachablePDSubLibs :: PD.PackageDescription -> Set.Set PD.UnqualComponentName
+reachablePDSubLibs pd =
+    go Set.empty seed
+  where
+    thisPn = packageName pd

+    sublibNamesIn :: [Dependency] -> [PD.UnqualComponentName]
+    sublibNamesIn = concatMap $ \(Dependency n _ libs) ->
+      if n == thisPn
+        then [ sn | PD.LSubLibName sn <- NonEmptySet.toList libs ]
+        else []
+
+    subLibMap :: Map.Map PD.UnqualComponentName [Dependency]
+    subLibMap = Map.fromList
+      [ (n, PD.targetBuildDepends (PD.libBuildInfo lib))
+      | lib <- PD.subLibraries pd
+      , PD.LSubLibName n <- [PD.libName lib]
+      ]
+
+    seed = sublibNamesIn $
+      maybe [] (PD.targetBuildDepends . PD.libBuildInfo) (PD.library pd)
+      ++ concatMap (PD.targetBuildDepends . PD.buildInfo) (PD.executables pd)
+
+    go acc [] = acc
+    go acc (n:rest)
+      | n `Set.member` acc = go acc rest
+      | otherwise = case Map.lookup n subLibMap of
+          Nothing   -> go acc rest
+          Just deps -> go (Set.insert n acc) (sublibNamesIn deps ++ rest)
+
